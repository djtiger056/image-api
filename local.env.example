SERVER_NAME=kling-api
SERVER_HOST=0.0.0.0
SERVER_PORT=18080
BROWSER_EXECUTABLE_PATH=/usr/bin/google-chrome-stable
# 可选：对外 API Key 鉴权。配置后，除 / 和 /ping 外，其余接口需带 x-api-key
SERVER_API_KEYS=

# Jimeng（可选，只有调用 Jimeng 能力时需要）
# 对外只暴露 x-api-key 时，服务会优先用请求头 Authorization；若缺失则回退用下面的服务端凭证
JIMENG_SESSIONID=
JIMENG_AUTHORIZATION=

# Kling 官方 API（推荐，稳定）
KLING_ACCESS_KEY=
KLING_SECRET_KEY=
KLING_API_TOKEN=
KLING_HTTP_TIMEOUT_MS=60000
KLING_POLL_INTERVAL_MS=1500
KLING_POLL_TIMEOUT_MS=180000

# Kling 网页模式（实验性，走网页登录态 + 免费额度）
# 可选值：official / web / auto
KLING_AUTH_MODE=auto
# 登录态优先级：请求内 provider_options > 下列环境变量 > 项目根目录 ./kling.json
KLING_WEB_STORAGE_STATE_JSON=
KLING_WEB_STORAGE_STATE_PATH=
KLING_WEB_COOKIES_JSON_PATH=
# 国内网页登录态建议使用 klingai.com；如果你持有国际站登录态，再改成 https://kling.ai/app/image/new
KLING_WEB_TARGET_URL=https://klingai.com/app/image/new
KLING_WEB_HEADLESS=true
KLING_WEB_WAIT_TIMEOUT_MS=180000
KLING_WEB_RESULT_POLL_INTERVAL_MS=2000
KLING_WEB_ARTIFACTS_DIR=./tmp/kling-web-provider
# 可选：持久化本地 web task，支持服务重启后继续 GET /v1/images/generations/:id 查询
KLING_WEB_TASKS_STATE_PATH=./tmp/kling-web-provider/tasks.json
