# ===========================
# images-api 环境变量配置
# 复制为 local.env 后填写:  cp local.env.example local.env
# ===========================

# --- 服务基础 ---
SERVER_NAME=images-api
SERVER_HOST=0.0.0.0
SERVER_PORT=8006

# --- 浏览器路径 ---
# 二选一: 优先 google-chrome-stable，其次 playwright 自带 chromium
# 如果留空且未安装 playwright chromium，Seedance/Kling 网页模式等依赖浏览器的功能将不可用
BROWSER_EXECUTABLE_PATH=/usr/bin/google-chrome-stable
# BROWSER_EXECUTABLE_PATH=/root/.cache/ms-playwright/chromium-*/chrome-linux/chrome

# --- 对外 API Key 鉴权（可选） ---
# 配置后除 / /ping /console /docs 外，其余接口需带 x-api-key 请求头
# 多个 key 逗号分隔
# SERVER_API_KEYS=

# ========================================
# 平台凭证（按需填写，不填则该平台功能不可用）
# ========================================

# --- 即梦 (Jimeng) ---
# 来源: jimeng.jianying.com 登录后 F12 → Application → Cookies → sessionid
JIMENG_SESSIONID=
# 或直接用 Authorization 值（优先级高于 SESSIONID）
# JIMENG_AUTHORIZATION=

# --- Kling 官方 API ---
KLING_ACCESS_KEY=
KLING_SECRET_KEY=
KLING_BASE_URL=https://api-singapore.klingai.com
KLING_HTTP_TIMEOUT_MS=60000
KLING_POLL_INTERVAL_MS=1500
KLING_POLL_TIMEOUT_MS=180000

# --- Kling 网页模式（可选，实验性） ---
# KLING_AUTH_MODE=auto
# KLING_WEB_TARGET_URL=https://klingai.com/app/image/new
# KLING_WEB_HEADLESS=true
# KLING_WEB_WAIT_TIMEOUT_MS=180000
# KLING_WEB_RESULT_POLL_INTERVAL_MS=2000
# KLING_WEB_ARTIFACTS_DIR=./tmp/kling-web-provider
# KLING_WEB_TASKS_STATE_PATH=./tmp/kling-web-provider/tasks.json
# KLING_WEB_STORAGE_STATE_JSON=
# KLING_WEB_STORAGE_STATE_PATH=
# KLING_WEB_COOKIES_JSON_PATH=

# --- 豆包 (Doubao) ---
# 来源: doubao.com 登录后 F12 → Application → Cookies → sessionid
DOUBAO_SESSIONID=
# 或直接用 Authorization 值
# DOUBAO_AUTHORIZATION=

# --- 小云雀 (XYQ) ---
XYQ_SESSIONID=
# 或直接用 Authorization 值
# XYQ_AUTHORIZATION=

# --- 千问 (Qwen) ---
# 来源: create.qianwen.com 登录后导出完整 Cookie 字符串或 Cookie-Editor JSON 数组
# 服务会把 Cookie 自动合并/续期到 qwen.json，减少手动更新频率
QWEN_COOKIE=
# 可选：自定义 Qwen Cookie 状态文件路径
# QWEN_COOKIE_STATE_PATH=./qwen.json
